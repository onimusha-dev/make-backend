{
    "name": "create-backend-monorepo",
    "private": true,
    "description": "Monorepo for make-backend CLI and website",
    "scripts": {
        "dev:website": "pnpm --filter website dev",
        "build:website": "pnpm --filter website build",
        "test:cli": "pnpm --filter make-backend test",
        "format": "prettier --write .",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,ts,tsx,json,md}": "prettier --write"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "devDependencies": {
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1"
    }
}
